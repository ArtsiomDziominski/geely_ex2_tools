<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_battery_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/widget_battery_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/widget_battery_icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:contentDescription="@string/battery_app_widget_label"
        android:src="@drawable/ic_notification_battery" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_battery_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="@string/battery_app_widget_placeholder"
            android:textColor="@color/widget_battery_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_battery_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="@string/battery_app_widget_label"
            android:textColor="@color/widget_battery_text_secondary"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/widget_battery_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="6dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_battery_progress" />
    </LinearLayout>
</LinearLayout>
